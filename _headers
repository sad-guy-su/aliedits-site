/*
  # ══════════════════════════════════════════
  # SECURITY HEADERS — Ali Edits
  # Deploy this _headers file alongside index.html
  # in your Netlify site root
  # ══════════════════════════════════════════

  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN

  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features you don't need
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Force HTTPS (HSTS) — 1 year
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # XSS Protection (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Content Security Policy
  # Allows: your own site, Google Fonts, Supabase, Jsdelivr CDN
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://lonvywqvcokjsejacmso.supabase.co; img-src 'self' data: https:; frame-src https://www.youtube.com https://player.vimeo.com https://drive.google.com; object-src 'none'; base-uri 'self';
